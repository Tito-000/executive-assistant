{%- comment -%}
  Memorama — Página de gracias después de enviar cotización.
  Lee el payload guardado en sessionStorage ('mmr_last_quote') y lo muestra.
{%- endcomment -%}

<style>
  .mmr-ty-wrap {
    max-width: 720px;
    margin: 0 auto;
    padding: 60px 20px 80px;
    font-family: inherit;
  }
  .mmr-ty-card {
    background: #fff;
    border-radius: 16px;
    padding: 40px 32px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.06);
    border: 1px solid #e8e2d8;
    text-align: center;
  }
  .mmr-ty-check {
    width: 80px;
    height: 80px;
    margin: 0 auto 20px;
    border-radius: 50%;
    background: #8ED320;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 24px rgba(142,211,32,0.3);
    animation: mmrTyPop 0.4s ease-out;
  }
  @keyframes mmrTyPop {
    0% { transform: scale(0); }
    60% { transform: scale(1.15); }
    100% { transform: scale(1); }
  }
  .mmr-ty-check svg { width: 42px; height: 42px; stroke: #fff; stroke-width: 4; fill: none; stroke-linecap: round; stroke-linejoin: round; }
  .mmr-ty-title { margin: 0 0 10px; font-size: 30px; font-weight: 800; color: #4A3726; line-height: 1.2; }
  .mmr-ty-sub { margin: 0 0 28px; font-size: 16px; color: #7a6a5a; line-height: 1.5; }
  .mmr-ty-sub strong { color: #4A3726; }

  .mmr-ty-summary {
    text-align: left;
    background: #faf7f4;
    border: 1px solid #e8e2d8;
    border-radius: 12px;
    padding: 22px 24px;
    margin: 24px 0 28px;
    font-size: 14px;
  }
  .mmr-ty-summary h3 { margin: 0 0 14px; font-size: 14px; font-weight: 700; color: #4A3726; text-transform: uppercase; letter-spacing: 0.05em; }
  .mmr-ty-row { display: flex; justify-content: space-between; gap: 16px; padding: 6px 0; border-bottom: 1px dashed #e8e2d8; }
  .mmr-ty-row:last-child { border-bottom: none; }
  .mmr-ty-label { color: #7a6a5a; flex-shrink: 0; }
  .mmr-ty-value { font-weight: 600; color: #2B1E13; text-align: right; }
  .mmr-ty-total { margin-top: 14px; padding-top: 14px; border-top: 2px solid #4A3726; display: flex; justify-content: space-between; align-items: center; }
  .mmr-ty-total strong { color: #4A3726; font-size: 22px; font-weight: 800; }

  .mmr-ty-steps {
    text-align: left;
    margin: 24px 0 28px;
    display: grid;
    gap: 14px;
  }
  .mmr-ty-step {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    padding: 14px 16px;
    background: #faf7f4;
    border-radius: 10px;
    border-left: 4px solid #4A3726;
  }
  .mmr-ty-step-num {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: #4A3726;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 700;
  }
  .mmr-ty-step-text { font-size: 14px; color: #2B1E13; line-height: 1.4; }
  .mmr-ty-step-text strong { color: #4A3726; }

  .mmr-ty-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 16px;
  }
  .mmr-ty-btn {
    display: inline-block;
    padding: 13px 28px;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.15s;
    border: none;
    cursor: pointer;
    font-family: inherit;
  }
  .mmr-ty-btn-primary { background: #4A3726; color: #fff; }
  .mmr-ty-btn-primary:hover { background: #3a2b1d; transform: translateY(-1px); box-shadow: 0 8px 20px rgba(74,55,38,0.3); }
  .mmr-ty-btn-whatsapp { background: #25D366; color: #fff; display: inline-flex; align-items: center; gap: 8px; }
  .mmr-ty-btn-whatsapp:hover { background: #1fb855; transform: translateY(-1px); box-shadow: 0 8px 20px rgba(37,211,102,0.3); }
  .mmr-ty-btn-secondary { background: #fff; color: #4A3726; border: 1.5px solid #e8e2d8; }
  .mmr-ty-btn-secondary:hover { border-color: #4A3726; }

  .mmr-ty-contact-info {
    margin-top: 32px;
    padding-top: 24px;
    border-top: 1px solid #e8e2d8;
    font-size: 13px;
    color: #7a6a5a;
    line-height: 1.6;
  }
  .mmr-ty-contact-info a { color: #4A3726; font-weight: 600; text-decoration: none; }

  @media (max-width: 540px) {
    .mmr-ty-wrap { padding: 32px 12px 60px; }
    .mmr-ty-card { padding: 28px 18px; }
    .mmr-ty-title { font-size: 24px; }
    .mmr-ty-actions { flex-direction: column; }
    .mmr-ty-btn { width: 100%; text-align: center; }
  }
</style>

<div class="mmr-ty-wrap">
  <div class="mmr-ty-card">
    <div class="mmr-ty-check">
      <svg viewBox="0 0 24 24"><polyline points="4,12 10,18 20,6"/></svg>
    </div>
    <h1 class="mmr-ty-title">¡Solicitud recibida!</h1>
    <p class="mmr-ty-sub">Gracias <strong id="mmrTyName">por tu cotización</strong>. Nuestro equipo está revisando tu logo y los detalles del pedido.</p>

    <div class="mmr-ty-summary" id="mmrTySummary" hidden>
      <h3>Resumen de tu solicitud</h3>
      <div id="mmrTySummaryBody"></div>
    </div>

    <div class="mmr-ty-steps">
      <div class="mmr-ty-step">
        <span class="mmr-ty-step-num">1</span>
        <span class="mmr-ty-step-text"><strong>Revisamos tu arte</strong> — Validamos que tu logo sea apto para la técnica elegida y te avisamos si necesita ajustes.</span>
      </div>
      <div class="mmr-ty-step">
        <span class="mmr-ty-step-num">2</span>
        <span class="mmr-ty-step-text"><strong>Te enviamos la cotización final</strong> — En menos de 24 horas hábiles recibirás el precio final confirmado por WhatsApp y email.</span>
      </div>
      <div class="mmr-ty-step">
        <span class="mmr-ty-step-num">3</span>
        <span class="mmr-ty-step-text"><strong>Confirmas y pagas</strong> — Te compartimos el link de pago. Al confirmar, entramos en producción.</span>
      </div>
      <div class="mmr-ty-step">
        <span class="mmr-ty-step-num">4</span>
        <span class="mmr-ty-step-text"><strong>Entregamos tu pedido</strong> — Recibes tu producto personalizado en el plazo acordado.</span>
      </div>
    </div>

    <div class="mmr-ty-actions">
      <a href="https://wa.me/18095772978" class="mmr-ty-btn mmr-ty-btn-whatsapp" target="_blank" rel="noopener">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.570-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.71.306 1.263.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.304-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893A11.821 11.821 0 0020.464 3.488"/></svg>
        Contactar por WhatsApp
      </a>
      <a href="/collections/all" class="mmr-ty-btn mmr-ty-btn-primary">Seguir viendo productos</a>
    </div>

    <div class="mmr-ty-contact-info">
      ¿Alguna duda? Escríbenos a <a href="mailto:hola@memorama.do">hola@memorama.do</a><br>
      o al WhatsApp <a href="https://wa.me/18095772978" target="_blank" rel="noopener">+1 (809) 577-2978</a>
    </div>
  </div>
</div>

<script>
(function() {
  const POSITION_LABELS = {
    center_front: 'Pecho centro',
    center_back: 'Espalda centro',
    left_chest: 'Pecho izquierdo',
    right_chest: 'Pecho derecho',
    left_sleeve: 'Manga izquierda',
    right_sleeve: 'Manga derecha',
    bespoke: 'Personalizada'
  };
  const TECHNIQUE_LABELS = {
    bordado: 'Bordado',
    serigrafia: 'Serigrafía',
    dtf: 'DTF',
    sublimacion: 'Sublimación'
  };

  function fmt(n) {
    return Number(n || 0).toLocaleString('es-DO', { maximumFractionDigits: 0 });
  }

  function esc(s) {
    return String(s || '').replace(/[&<>"']/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
  }

  let data = null;
  try {
    data = JSON.parse(sessionStorage.getItem('mmr_last_quote') || 'null');
  } catch (e) {}

  if (!data) return;

  if (data.contact && data.contact.name) {
    document.getElementById('mmrTyName').textContent = esc(data.contact.name.split(' ')[0]);
  }

  const summaryEl = document.getElementById('mmrTySummary');
  const bodyEl = document.getElementById('mmrTySummaryBody');
  if (!summaryEl || !bodyEl) return;

  let html = '';
  if (data.product_title) html += '<div class="mmr-ty-row"><span class="mmr-ty-label">Producto</span><span class="mmr-ty-value">' + esc(data.product_title) + '</span></div>';
  if (data.technique) html += '<div class="mmr-ty-row"><span class="mmr-ty-label">Técnica</span><span class="mmr-ty-value">' + esc(TECHNIQUE_LABELS[data.technique] || data.technique) + '</span></div>';
  if (data.positions && data.positions.length) {
    const names = data.positions.map(p => POSITION_LABELS[p] || p).join(', ');
    html += '<div class="mmr-ty-row"><span class="mmr-ty-label">Posiciones</span><span class="mmr-ty-value">' + esc(names) + '</span></div>';
  }
  if (data.matrix) {
    const rows = [];
    Object.keys(data.matrix).forEach(color => {
      const sizes = data.matrix[color] || {};
      const parts = Object.keys(sizes).filter(s => sizes[s] > 0).map(s => s + ':' + sizes[s]);
      if (parts.length) rows.push(esc(color) + ' (' + parts.join(', ') + ')');
    });
    if (rows.length) html += '<div class="mmr-ty-row"><span class="mmr-ty-label">Colores y tallas</span><span class="mmr-ty-value">' + rows.join('<br>') + '</span></div>';
  }
  if (data.quantity) html += '<div class="mmr-ty-row"><span class="mmr-ty-label">Cantidad total</span><span class="mmr-ty-value">' + data.quantity + ' un</span></div>';
  if (data.pricing && data.pricing.discount_pct) html += '<div class="mmr-ty-row"><span class="mmr-ty-label">Descuento volumen</span><span class="mmr-ty-value">-' + data.pricing.discount_pct + '%</span></div>';
  if (data.pricing && data.pricing.total) {
    html += '<div class="mmr-ty-total"><span>Total estimado</span><strong>RD$ ' + fmt(data.pricing.total) + '</strong></div>';
  }

  bodyEl.innerHTML = html;
  summaryEl.hidden = false;
})();
</script>

{% schema %}
{
  "name": "Memorama - Gracias",
  "settings": [],
  "presets": [
    { "name": "Memorama - Gracias" }
  ]
}
{% endschema %}
