{% comment %}
  Memorama — Cotizador de Bordado/Personalización
  ==================================================
  Snippet que se inserta DENTRO de la página de producto.

  USO:
  {% render 'cotizador-bordado', product: product %}

  Incluye:
  - Subida de logo (sin preview visual)
  - Selector de técnica (bordado, serigrafía, DTF, sublimación)
  - Selector de posición(es)
  - Cantidad con precio en vivo y descuento por volumen
  - Botón que envía la cotización
{% endcomment %}

<link rel="stylesheet" href="{{ 'cotizador-bordado.css' | asset_url }}">

{% comment %} Ocultar bloques nativos del theme que duplican info del cotizador {% endcomment %}
<style>
  /* Oculta precio nativo del theme (aparece como "Desde: RD$ 0.00") */
  #price-{{ section.id }},
  .product__info-wrapper .price,
  .product .price--large { display: none !important; }

  /* Oculta variant picker nativo (Color + Size del theme) */
  .product-form__input--variant,
  .product-form__input[data-option-index],
  variant-selects,
  variant-radios,
  .product-form__input--pill,
  .product-form__input--swatch,
  fieldset.product-form__input { display: none !important; }

  /* Oculta el "Desde:" label si existe */
  .product__info-wrapper .caption-with-letter-spacing { display: none !important; }
</style>

<div class="mmr-cotizador" data-product-handle="{{ product.handle }}" data-product-id="{{ product.id }}">

  <div class="mmr-header">
    <h3 class="mmr-title">Personaliza tu pedido</h3>
    <p class="mmr-subtitle">Sube tu logo, elige t&#233;cnica y cantidad - calcula tu precio al instante</p>
  </div>

  {% comment %} ---------- 1. SUBIDA DE LOGO ---------- {% endcomment %}
  <div class="mmr-section">
    <label class="mmr-label">
      <span class="mmr-step-num">1</span>
      Sube tu logo
    </label>
    <label for="mmrLogoInput-{{ product.id }}" class="mmr-upload-zone mmr-upload-zone-full" id="mmrUploadZone-{{ product.id }}">
      <div class="mmr-upload-icon">
        <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
          <polyline points="17 8 12 3 7 8"></polyline>
          <line x1="12" y1="3" x2="12" y2="15"></line>
        </svg>
      </div>
      <div class="mmr-upload-text">Arrastra o haz clic para subir</div>
      <div class="mmr-upload-hint">PNG, JPG, SVG, PDF - Max 10MB</div>
      <input type="file" id="mmrLogoInput-{{ product.id }}" class="mmr-logo-input" accept="image/*,.pdf" hidden>
    </label>
  </div>

  {% comment %} ---------- 2. TECNICA ---------- {% endcomment %}
  <div class="mmr-section">
    <label class="mmr-label">
      <span class="mmr-step-num">2</span>
      Elige t&#233;cnica
    </label>
    <div class="mmr-technique-grid">
      <div class="mmr-tech-card" data-tech="bordado">
        <div class="mmr-tech-name">Bordado</div>
        <div class="mmr-tech-desc">Durabilidad premium</div>
        <div class="mmr-tech-cost">+<span data-price="bordado">150</span> RD$/un</div>
      </div>
      <div class="mmr-tech-card" data-tech="serigrafia">
        <div class="mmr-tech-name">Serigraf&#237;a</div>
        <div class="mmr-tech-desc">Econ&#243;mico en volumen</div>
        <div class="mmr-tech-cost">+<span data-price="serigrafia">80</span> RD$/un</div>
      </div>
      <div class="mmr-tech-card" data-tech="dtf">
        <div class="mmr-tech-name">DTF</div>
        <div class="mmr-tech-desc">Full color, sin m&#237;nimo</div>
        <div class="mmr-tech-cost">+<span data-price="dtf">100</span> RD$/un</div>
      </div>
      <div class="mmr-tech-card" data-tech="sublimacion">
        <div class="mmr-tech-name">Sublimaci&#243;n</div>
        <div class="mmr-tech-desc">Solo blancos/claros</div>
        <div class="mmr-tech-cost">+<span data-price="sublimacion">90</span> RD$/un</div>
      </div>
    </div>
  </div>

  {% comment %} ---------- 3. POSICION ---------- {% endcomment %}
  {%- comment -%}
    Camiseta manga larga estilo top player (vista frontal y trasera).
    Gris claro con borde oscuro. Zona de impresion en azul marca.
  {%- endcomment -%}
  {%- capture shirt_front -%}
    <g fill="#fff" stroke="#7a7a7a" stroke-width="1.2" stroke-linejoin="round" stroke-linecap="round">
      <path d="M30 16 L42 10 L50 14 L58 10 L70 16 L86 22 L92 40 L78 46 L78 88 L22 88 L22 46 L8 40 L14 22 Z"/>
      <path d="M42 10 Q50 20 58 10" fill="none"/>
    </g>
  {%- endcapture -%}
  {%- capture shirt_back -%}
    <g fill="#fff" stroke="#7a7a7a" stroke-width="1.2" stroke-linejoin="round" stroke-linecap="round">
      <path d="M30 16 L42 12 L50 10 L58 12 L70 16 L86 22 L92 40 L78 46 L78 88 L22 88 L22 46 L8 40 L14 22 Z"/>
      <path d="M42 12 Q50 16 58 12" fill="none"/>
    </g>
  {%- endcapture -%}

  <div class="mmr-section">
    <label class="mmr-label">
      <span class="mmr-step-num">3</span>
      Posici&#243;n del logo
      <span class="mmr-hint">(puedes elegir m&#225;s de una)</span>
    </label>
    <div class="mmr-pos-grid">
      <label class="mmr-pos-card">
        <input type="checkbox" value="center_front">
        <div class="mmr-pos-icon">
          <svg viewBox="0 0 100 100">{{ shirt_front }}<rect x="38" y="34" width="24" height="28" fill="#2F8FB8" rx="1"/></svg>
        </div>
        <div class="mmr-pos-info"><span class="mmr-pos-name">Pecho centro</span><span class="mmr-pos-cost">+120</span></div>
      </label>
      <label class="mmr-pos-card">
        <input type="checkbox" value="center_back">
        <div class="mmr-pos-icon">
          <svg viewBox="0 0 100 100">{{ shirt_back }}<rect x="34" y="32" width="32" height="36" fill="#2F8FB8" rx="1"/></svg>
        </div>
        <div class="mmr-pos-info"><span class="mmr-pos-name">Espalda centro</span><span class="mmr-pos-cost">+150</span></div>
      </label>
      <label class="mmr-pos-card">
        <input type="checkbox" value="left_chest">
        <div class="mmr-pos-icon">
          <svg viewBox="0 0 100 100">{{ shirt_front }}<rect x="36" y="30" width="10" height="10" fill="#2F8FB8" rx="1"/></svg>
        </div>
        <div class="mmr-pos-info"><span class="mmr-pos-name">Pecho izquierdo</span><span class="mmr-pos-cost">+60</span></div>
      </label>
      <label class="mmr-pos-card">
        <input type="checkbox" value="right_chest">
        <div class="mmr-pos-icon">
          <svg viewBox="0 0 100 100">{{ shirt_front }}<rect x="54" y="30" width="10" height="10" fill="#2F8FB8" rx="1"/></svg>
        </div>
        <div class="mmr-pos-info"><span class="mmr-pos-name">Pecho derecho</span><span class="mmr-pos-cost">+60</span></div>
      </label>
      <label class="mmr-pos-card">
        <input type="checkbox" value="left_sleeve">
        <div class="mmr-pos-icon">
          <svg viewBox="0 0 100 100">{{ shirt_front }}<rect x="12" y="32" width="8" height="8" fill="#2F8FB8" rx="1"/></svg>
        </div>
        <div class="mmr-pos-info"><span class="mmr-pos-name">Manga izquierda</span><span class="mmr-pos-cost">+50</span></div>
      </label>
      <label class="mmr-pos-card">
        <input type="checkbox" value="right_sleeve">
        <div class="mmr-pos-icon">
          <svg viewBox="0 0 100 100">{{ shirt_front }}<rect x="80" y="32" width="8" height="8" fill="#2F8FB8" rx="1"/></svg>
        </div>
        <div class="mmr-pos-info"><span class="mmr-pos-name">Manga derecha</span><span class="mmr-pos-cost">+50</span></div>
      </label>
      <label class="mmr-pos-card">
        <input type="checkbox" value="bespoke">
        <div class="mmr-pos-icon">
          <svg viewBox="0 0 100 100">{{ shirt_front }}<text x="50" y="58" text-anchor="middle" font-family="Arial, sans-serif" font-size="28" font-weight="700" fill="#4A3726">P</text></svg>
        </div>
        <div class="mmr-pos-info"><span class="mmr-pos-name">Personalizada</span><span class="mmr-pos-cost">+100</span></div>
      </label>
    </div>
    <p class="mmr-pos-note">&#128161; Personalizada = ubicaci&#243;n libre (cuello, bolsillo, bajo, etc). Detalla en los comentarios.</p>
  </div>

  {% comment %} ---------- 4. MATRIZ COLOR x TALLA ---------- {% endcomment %}
  {% if product.has_only_default_variant == false %}
    {%- liquid
      assign color_option_index = -1
      assign size_option_index = -1
      for opt in product.options_with_values
        assign n = opt.name | downcase
        if n contains 'color' or n contains 'colour'
          assign color_option_index = forloop.index0
        elsif n contains 'talla' or n contains 'size' or n contains 'tama'
          assign size_option_index = forloop.index0
        endif
      endfor
      assign color_values = ''
      assign size_values = ''
      if color_option_index >= 0
        assign color_option = product.options_with_values[color_option_index]
        assign color_values = color_option.values
      endif
      if size_option_index >= 0
        assign size_option = product.options_with_values[size_option_index]
        assign size_values = size_option.values
      endif
    -%}
    <div class="mmr-section">
      <label class="mmr-label" id="mmrMatrixLabel-{{ product.id }}">
        <span class="mmr-step-num">4</span>
        <span class="mmr-matrix-label-text">Elige colores y cantidad</span>
        <span class="mmr-hint">(selecciona uno o varios colores)</span>
      </label>

      {%- if color_option_index >= 0 -%}
      <div class="mmr-color-picker" id="mmrColorPicker-{{ product.id }}">
        {% for value in color_values %}
          <button type="button" class="mmr-variant-swatch" data-color="{{ value | escape }}" aria-label="{{ value | escape }}" title="{{ value | escape }}"><span class="mmr-swatch-dot" data-color-name="{{ value | escape | downcase }}"></span></button>
        {% endfor %}
      </div>
      {%- endif -%}

      <div class="mmr-matrix-wrap" id="mmrMatrixWrap-{{ product.id }}">
        {%- if size_option_index >= 0 -%}
        <div class="mmr-matrix-header">
          <div class="mmr-matrix-color-label">Color</div>
          {% for s in size_values %}
            <div class="mmr-matrix-size-label">{{ s }}</div>
          {% endfor %}
          <div class="mmr-matrix-row-total">Subtotal</div>
        </div>
        {%- endif -%}
        <div class="mmr-matrix-rows" id="mmrMatrixRows-{{ product.id }}"></div>
        <div class="mmr-matrix-empty" id="mmrMatrixEmpty-{{ product.id }}">Selecciona al menos un color para abrir las cantidades por talla.</div>
      </div>

      <div class="mmr-matrix-total-row">
        <span class="mmr-matrix-total-label">Total de unidades:</span>
        <span class="mmr-matrix-total-value" id="mmrMatrixTotal-{{ product.id }}">0</span>
      </div>

      <script type="application/json" id="mmrVariants-{{ product.id }}">
        {{ product.variants | json }}
      </script>
      <script type="application/json" id="mmrSizes-{{ product.id }}">
        {{ size_values | json }}
      </script>
      <script type="application/json" id="mmrOptionIdx-{{ product.id }}">
        {"color": {{ color_option_index }}, "size": {{ size_option_index }}}
      </script>
    </div>
  {% endif %}

  {% comment %} ---------- 5. CANTIDAD (legacy — oculta si hay matriz) ---------- {% endcomment %}
  <div class="mmr-section mmr-section-qty-legacy"{% if product.has_only_default_variant == false %} hidden{% endif %}>
    <label class="mmr-label">
      <span class="mmr-step-num">{% if product.has_only_default_variant %}4{% else %}5{% endif %}</span>
      Cantidad
    </label>
    <div class="mmr-qty-row">
      <div class="mmr-qty-input">
        <button type="button" data-qty="minus">-</button>
        <input type="number" id="mmrQty-{{ product.id }}" value="1" min="1" max="10000">
        <button type="button" data-qty="plus">+</button>
      </div>
      <div class="mmr-volume-tip" id="mmrVolumeTip-{{ product.id }}">Agrega m&#225;s para ahorrar</div>
    </div>
    <div class="mmr-volume-tiers">
      <div class="mmr-tier" data-min="10" data-max="24" data-disc="5">10-24 un · -5%</div>
      <div class="mmr-tier" data-min="25" data-max="49" data-disc="10">25-49 un · -10%</div>
      <div class="mmr-tier" data-min="50" data-max="99" data-disc="18">50-99 un · -18%</div>
      <div class="mmr-tier" data-min="100" data-max="249" data-disc="25">100-249 un · -25%</div>
      <div class="mmr-tier" data-min="250" data-max="99999" data-disc="32">250+ un · -32%</div>
    </div>
  </div>

  {% comment %} ---------- PRECIO EN VIVO + CTA ---------- {% endcomment %}
  <div class="mmr-price-box" id="mmrPriceBox-{{ product.id }}">
    <div class="mmr-price-label">Tu precio estimado</div>
    <div class="mmr-price-total">
      <span class="mmr-currency">RD$</span>
      <span class="mmr-price-number" id="mmrPriceNumber-{{ product.id }}">---</span>
    </div>
    <div class="mmr-price-unit" id="mmrPriceUnit-{{ product.id }}">Completa los pasos para ver tu precio</div>
    <div class="mmr-price-breakdown" id="mmrPriceBreakdown-{{ product.id }}"></div>
  </div>

  <button type="button" class="mmr-cta-btn" id="mmrCtaBtn-{{ product.id }}" disabled>
    Solicitar cotizaci&#243;n
  </button>

  <p class="mmr-disclaimer">
    Enviaremos tu solicitud a Memorama. Validar&#225;n el logo y te contactar&#225;n con el link de pago.
  </p>

  {% comment %} ---------- MODAL DE CONTACTO ---------- {% endcomment %}
  <div class="mmr-modal-overlay" id="mmrModalOverlay-{{ product.id }}" hidden>
    <div class="mmr-modal" role="dialog" aria-labelledby="mmrModalTitle-{{ product.id }}">
      <button type="button" class="mmr-modal-close" id="mmrModalClose-{{ product.id }}" aria-label="Cerrar">&times;</button>

      <div class="mmr-modal-header">
        <h3 class="mmr-modal-title" id="mmrModalTitle-{{ product.id }}">Un &#250;ltimo paso</h3>
        <p class="mmr-modal-subtitle">Comp&#225;rtenos tus datos y te enviaremos la cotizaci&#243;n en minutos</p>
      </div>

      {% comment %} Resumen del pedido {% endcomment %}
      <div class="mmr-modal-summary" id="mmrModalSummary-{{ product.id }}"></div>

      <form class="mmr-modal-form" id="mmrModalForm-{{ product.id }}">
        <div class="mmr-form-row mmr-form-row-2">
          <div class="mmr-form-field">
            <label class="mmr-form-label">Nombre completo <span class="mmr-req">*</span></label>
            <input type="text" name="name" required placeholder="Tu nombre">
          </div>
          <div class="mmr-form-field">
            <label class="mmr-form-label">Tel&#233;fono / WhatsApp <span class="mmr-req">*</span></label>
            <input type="tel" name="phone" required placeholder="+1 809-000-0000">
          </div>
        </div>

        <div class="mmr-form-field">
          <label class="mmr-form-label">Email <span class="mmr-req">*</span></label>
          <input type="email" name="email" required placeholder="tucorreo@ejemplo.com">
        </div>

        <div class="mmr-form-field">
          <label class="mmr-form-label">Empresa / Instituci&#243;n <span class="mmr-opt">(opcional)</span></label>
          <input type="text" name="company" placeholder="Nombre de la empresa">
        </div>

        <div class="mmr-form-field">
          <label class="mmr-form-label">Fecha de entrega deseada <span class="mmr-opt">(opcional)</span></label>
          <input type="date" name="deadline">
        </div>

        <div class="mmr-form-field">
          <label class="mmr-form-label">Comentarios adicionales <span class="mmr-opt">(opcional)</span></label>
          <textarea name="comments" rows="3" placeholder="Detalles del pedido, referencias de color, consideraciones especiales..."></textarea>
        </div>

        <label class="mmr-form-checkbox">
          <input type="checkbox" name="terms" required>
          <span>Acepto los <a href="/policies/terms-of-service" target="_blank">T&#233;rminos y Condiciones</a> <span class="mmr-req">*</span></span>
        </label>

        <button type="submit" class="mmr-modal-submit" id="mmrModalSubmit-{{ product.id }}">
          Enviar solicitud de cotizaci&#243;n
        </button>

        <p class="mmr-modal-disclaimer">
          Te responderemos por WhatsApp o email en menos de 24 horas con tu cotizaci&#243;n final.
        </p>
      </form>
    </div>
  </div>
</div>

<script>
(function() {
  const PRODUCT_BASE_PRICE = {{ product.metafields.memorama.base_price | default: 0 }};
  const PRODUCT_ID = {{ product.id }};
  const PRODUCT_HANDLE = '{{ product.handle }}';
  const PRODUCT_TITLE = {{ product.title | json }};

  const PRICING = {
    base: PRODUCT_BASE_PRICE,
    techniques: {
      bordado: { cost: 150, min: 10 },
      serigrafia: { cost: 80, min: 25 },
      dtf: { cost: 100, min: 1 },
      sublimacion: { cost: 90, min: 1 }
    },
    positions: {
      center_front: 120, center_back: 150,
      left_chest: 60, right_chest: 60,
      left_sleeve: 50, right_sleeve: 50,
      bespoke: 100
    },
    volumeDiscounts: [
      { min: 1, max: 9, disc: 0 },
      { min: 10, max: 24, disc: 0.05 },
      { min: 25, max: 49, disc: 0.10 },
      { min: 50, max: 99, disc: 0.18 },
      { min: 100, max: 249, disc: 0.25 },
      { min: 250, max: 99999, disc: 0.32 }
    ]
  };

  window.MMR_INIT = window.MMR_INIT || {};
  window.MMR_INIT[PRODUCT_ID] = { PRICING, PRODUCT_HANDLE, PRODUCT_TITLE };
})();
</script>

<script src="{{ 'cotizador-bordado.js' | asset_url }}" defer></script>
