{% doc %}
  @prompt
    PROMPT PARA SHOPIFY AI
    Sección de Formulario “Asesoramiento de expertos” (con ID editable)
    
    Crea una sección personalizada de Shopify que contenga un formulario de cotización / asesoramiento, optimizado para desktop y mobile, similar al diseño de un formulario profesional B2B.
    
    🔑 REQUISITO CLAVE (OBLIGATORIO)
    
    El formulario debe tener un ID HTML fijo y editable, por ejemplo:
    
    id="form-cotizacion-experto"
    
    
    Este ID debe estar aplicado al <form> principal o al contenedor del formulario.
    
    El ID se usará para:
    
    Scroll desde botones
    
    Tracking
    
    Integraciones externas
    
    🧾 CONTENIDO DEL FORMULARIO
    Encabezado
    
    Título (H1):
    “¿Necesita asesoramiento de expertos?”
    
    Subtítulo:
    “Complete los detalles a continuación y nos comunicaremos con usted en 15 minutos o menos.”
    
    Campos del formulario
    
    Fila 1 (desktop / stack en mobile):
    
    Fecha límite de entrega (campo tipo fecha)
    
    Presupuesto
    
    Fila 2:
    
    Nombre de pila (requerido)
    
    Apellido
    
    Fila 3:
    
    Teléfono (requerido)
    
    Correo electrónico (requerido)
    
    Productos necesarios (checkbox – requerido)
    
    Mostrar un grupo de checkboxes con estas opciones:
    
    Camisetas
    
    Camisas polo
    
    Sudaderas con capucha
    
    Sombreros y gorras
    
    Chaquetas
    
    Alta visibilidad
    
    Bolsas de mano
    
    Toallas
    
    Cordones
    
    Bolígrafos
    
    Medias
    
    Otros
    
    Campo final
    
    Más información (textarea grande, requerido)
    
    Placeholder sugerido:
    “Cantidad aproximada, tipo de impresión, fecha, referencias…”
    
    Botón CTA
    
    Texto:
    “Solicitar asesoramiento experto →”
    
    Botón ancho, redondeado, color corporativo (rosa).
    
    Centrado.
    
    📱 RESPONSIVE (MUY IMPORTANTE)
    
    Desktop:
    
    Formulario en 2 columnas.
    
    Espaciado amplio.
    
    Mobile:
    
    Todos los campos en una sola columna.
    
    Botón CTA ancho (100%).
    
    Tipografía grande y legible.
    
    ⚙️ CONFIGURACIÓN SHOPIFY
    
    Crear como Section de Shopify.
    
    HTML + CSS + Liquid.
    
    Campos editables desde el Customizer:
    
    Textos
    
    Placeholder
    
    Texto del botón
    
    Compatible con el tema Dawn.
    
    🎯 RESULTADO ESPERADO
    
    Genera la sección completa con:
    
    Diseño profesional
    
    UX clara
    
    Formulario con ID fijo (
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-expert-form-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-expert-form__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-expert-form__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-expert-form__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 16px;
    font-weight: 600;
  }

  .ai-expert-form__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    opacity: 0.9;
  }

  .ai-expert-form__form-wrapper-{{ ai_gen_id }} {
    background-color: {{ block.settings.form_background_color }};
    padding: 32px;
    border-radius: {{ block.settings.form_border_radius }}px;
  }

  .ai-expert-form__row-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 16px;
  }

  .ai-expert-form__field-{{ ai_gen_id }} {
    margin-bottom: 16px;
  }

  .ai-expert-form__label-{{ ai_gen_id }} {
    display: block;
    font-size: 14px;
    font-weight: 500;
    color: {{ block.settings.text_color }};
    margin-bottom: 8px;
  }

  .ai-expert-form__required-{{ ai_gen_id }} {
    color: {{ block.settings.required_color }};
  }

  .ai-expert-form__input-{{ ai_gen_id }},
  .ai-expert-form__textarea-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: 15px;
    color: {{ block.settings.text_color }};
    background-color: {{ block.settings.input_background_color }};
    transition: border-color 0.2s ease;
  }

  .ai-expert-form__input-{{ ai_gen_id }}:focus,
  .ai-expert-form__textarea-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.input_focus_color }};
  }

  .ai-expert-form__textarea-{{ ai_gen_id }} {
    min-height: 120px;
    resize: vertical;
  }

  .ai-expert-form__checkbox-group-{{ ai_gen_id }} {
    margin-bottom: 16px;
  }

  .ai-expert-form__checkbox-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-top: 8px;
  }

  .ai-expert-form__checkbox-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ai-expert-form__checkbox-{{ ai_gen_id }} {
    width: 18px;
    height: 18px;
    cursor: pointer;
  }

  .ai-expert-form__checkbox-label-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.text_color }};
    cursor: pointer;
    margin: 0;
  }

  .ai-expert-form__button-{{ ai_gen_id }} {
    width: 100%;
    padding: 16px 32px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s ease;
    margin-top: 8px;
  }

  .ai-expert-form__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-expert-form__success-{{ ai_gen_id }} {
    padding: 16px;
    background-color: {{ block.settings.success_bg_color }};
    color: {{ block.settings.success_text_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    margin-top: 16px;
    text-align: center;
  }

  .ai-expert-form__error-{{ ai_gen_id }} {
    padding: 16px;
    background-color: {{ block.settings.error_bg_color }};
    color: {{ block.settings.error_text_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    margin-top: 16px;
  }

  @media screen and (max-width: 749px) {
    .ai-expert-form-{{ ai_gen_id }} {
      padding: 32px 16px;
    }

    .ai-expert-form__form-wrapper-{{ ai_gen_id }} {
      padding: 24px 16px;
    }

    .ai-expert-form__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-expert-form__subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 0.9 }}px;
    }

    .ai-expert-form__row-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-expert-form__checkbox-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }
  }
{% endstyle %}

<div class="ai-expert-form-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-expert-form__container-{{ ai_gen_id }}">
    <div class="ai-expert-form__header-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <h1 class="ai-expert-form__title-{{ ai_gen_id }}">{{ block.settings.title }}</h1>
      {% endif %}
      {% if block.settings.subtitle != blank %}
        <p class="ai-expert-form__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
      {% endif %}
    </div>

    <div class="ai-expert-form__form-wrapper-{{ ai_gen_id }}">
      {%- form 'contact', id: block.settings.form_id -%}
        <input type="hidden" name="contact[form_type]" value="expert_consultation">

        <div class="ai-expert-form__row-{{ ai_gen_id }}">
          <div class="ai-expert-form__field-{{ ai_gen_id }}">
            <label class="ai-expert-form__label-{{ ai_gen_id }}" for="delivery-date-{{ ai_gen_id }}">
              {{ block.settings.delivery_date_label }}
            </label>
            <input
              type="date"
              id="delivery-date-{{ ai_gen_id }}"
              name="contact[delivery_date]"
              class="ai-expert-form__input-{{ ai_gen_id }}"
            >
          </div>

          <div class="ai-expert-form__field-{{ ai_gen_id }}">
            <label class="ai-expert-form__label-{{ ai_gen_id }}" for="budget-{{ ai_gen_id }}">
              {{ block.settings.budget_label }}
            </label>
            <input
              type="text"
              id="budget-{{ ai_gen_id }}"
              name="contact[budget]"
              class="ai-expert-form__input-{{ ai_gen_id }}"
              placeholder="{{ block.settings.budget_placeholder }}"
            >
          </div>
        </div>

        <div class="ai-expert-form__row-{{ ai_gen_id }}">
          <div class="ai-expert-form__field-{{ ai_gen_id }}">
            <label class="ai-expert-form__label-{{ ai_gen_id }}" for="first-name-{{ ai_gen_id }}">
              {{ block.settings.first_name_label }} <span class="ai-expert-form__required-{{ ai_gen_id }}">*</span>
            </label>
            <input
              type="text"
              id="first-name-{{ ai_gen_id }}"
              name="contact[first_name]"
              class="ai-expert-form__input-{{ ai_gen_id }}"
              placeholder="{{ block.settings.first_name_placeholder }}"
              required
            >
          </div>

          <div class="ai-expert-form__field-{{ ai_gen_id }}">
            <label class="ai-expert-form__label-{{ ai_gen_id }}" for="last-name-{{ ai_gen_id }}">
              {{ block.settings.last_name_label }}
            </label>
            <input
              type="text"
              id="last-name-{{ ai_gen_id }}"
              name="contact[last_name]"
              class="ai-expert-form__input-{{ ai_gen_id }}"
              placeholder="{{ block.settings.last_name_placeholder }}"
            >
          </div>
        </div>

        <div class="ai-expert-form__row-{{ ai_gen_id }}">
          <div class="ai-expert-form__field-{{ ai_gen_id }}">
            <label class="ai-expert-form__label-{{ ai_gen_id }}" for="phone-{{ ai_gen_id }}">
              {{ block.settings.phone_label }} <span class="ai-expert-form__required-{{ ai_gen_id }}">*</span>
            </label>
            <input
              type="tel"
              id="phone-{{ ai_gen_id }}"
              name="contact[phone]"
              class="ai-expert-form__input-{{ ai_gen_id }}"
              placeholder="{{ block.settings.phone_placeholder }}"
              required
            >
          </div>

          <div class="ai-expert-form__field-{{ ai_gen_id }}">
            <label class="ai-expert-form__label-{{ ai_gen_id }}" for="email-{{ ai_gen_id }}">
              {{ block.settings.email_label }} <span class="ai-expert-form__required-{{ ai_gen_id }}">*</span>
            </label>
            <input
              type="email"
              id="email-{{ ai_gen_id }}"
              name="contact[email]"
              class="ai-expert-form__input-{{ ai_gen_id }}"
              placeholder="{{ block.settings.email_placeholder }}"
              value="{{ form.email }}"
              autocorrect="off"
              autocapitalize="off"
              autocomplete="email"
              {% if form.errors %}
                aria-invalid="true"
                aria-describedby="ai-expert-form-error-{{ ai_gen_id }}"
              {% endif %}
              required
            >
          </div>
        </div>

        <div class="ai-expert-form__checkbox-group-{{ ai_gen_id }}">
          <label class="ai-expert-form__label-{{ ai_gen_id }}">
            {{ block.settings.products_label }} <span class="ai-expert-form__required-{{ ai_gen_id }}">*</span>
          </label>
          <div class="ai-expert-form__checkbox-grid-{{ ai_gen_id }}">
            <div class="ai-expert-form__checkbox-item-{{ ai_gen_id }}">
              <input
                type="checkbox"
                id="product-tshirts-{{ ai_gen_id }}"
                name="contact[products][]"
                value="Camisetas"
                class="ai-expert-form__checkbox-{{ ai_gen_id }}"
              >
              <label for="product-tshirts-{{ ai_gen_id }}" class="ai-expert-form__checkbox-label-{{ ai_gen_id }}">Camisetas</label>
            </div>
            <div class="ai-expert-form__checkbox-item-{{ ai_gen_id }}">
              <input
                type="checkbox"
                id="product-polo-{{ ai_gen_id }}"
                name="contact[products][]"
                value="Camisas polo"
                class="ai-expert-form__checkbox-{{ ai_gen_id }}"
              >
              <label for="product-polo-{{ ai_gen_id }}" class="ai-expert-form__checkbox-label-{{ ai_gen_id }}">Camisas polo</label>
            </div>
            <div class="ai-expert-form__checkbox-item-{{ ai_gen_id }}">
              <input
                type="checkbox"
                id="product-hoodies-{{ ai_gen_id }}"
                name="contact[products][]"
                value="Sudaderas con capucha"
                class="ai-expert-form__checkbox-{{ ai_gen_id }}"
              >
              <label for="product-hoodies-{{ ai_gen_id }}" class="ai-expert-form__checkbox-label-{{ ai_gen_id }}">Sudaderas con capucha</label>
            </div>
            <div class="ai-expert-form__checkbox-item-{{ ai_gen_id }}">
              <input
                type="checkbox"
                id="product-hats-{{ ai_gen_id }}"
                name="contact[products][]"
                value="Sombreros y gorras"
                class="ai-expert-form__checkbox-{{ ai_gen_id }}"
              >
              <label for="product-hats-{{ ai_gen_id }}" class="ai-expert-form__checkbox-label-{{ ai_gen_id }}">Sombreros y gorras</label>
            </div>
            <div class="ai-expert-form__checkbox-item-{{ ai_gen_id }}">
              <input
                type="checkbox"
                id="product-jackets-{{ ai_gen_id }}"
                name="contact[products][]"
                value="Chaquetas"
                class="ai-expert-form__checkbox-{{ ai_gen_id }}"
              >
              <label for="product-jackets-{{ ai_gen_id }}" class="ai-expert-form__checkbox-label-{{ ai_gen_id }}">Chaquetas</label>
            </div>
            <div class="ai-expert-form__checkbox-item-{{ ai_gen_id }}">
              <input
                type="checkbox"
                id="product-visibility-{{ ai_gen_id }}"
                name="contact[products][]"
                value="Alta visibilidad"
                class="ai-expert-form__checkbox-{{ ai_gen_id }}"
              >
              <label for="product-visibility-{{ ai_gen_id }}" class="ai-expert-form__checkbox-label-{{ ai_gen_id }}">Alta visibilidad</label>
            </div>
            <div class="ai-expert-form__checkbox-item-{{ ai_gen_id }}">
              <input
                type="checkbox"
                id="product-bags-{{ ai_gen_id }}"
                name="contact[products][]"
                value="Bolsas de mano"
                class="ai-expert-form__checkbox-{{ ai_gen_id }}"
              >
              <label for="product-bags-{{ ai_gen_id }}" class="ai-expert-form__checkbox-label-{{ ai_gen_id }}">Bolsas de mano</label>
            </div>
            <div class="ai-expert-form__checkbox-item-{{ ai_gen_id }}">
              <input
                type="checkbox"
                id="product-towels-{{ ai_gen_id }}"
                name="contact[products][]"
                value="Toallas"
                class="ai-expert-form__checkbox-{{ ai_gen_id }}"
              >
              <label for="product-towels-{{ ai_gen_id }}" class="ai-expert-form__checkbox-label-{{ ai_gen_id }}">Toallas</label>
            </div>
            <div class="ai-expert-form__checkbox-item-{{ ai_gen_id }}">
              <input
                type="checkbox"
                id="product-lanyards-{{ ai_gen_id }}"
                name="contact[products][]"
                value="Cordones"
                class="ai-expert-form__checkbox-{{ ai_gen_id }}"
              >
              <label for="product-lanyards-{{ ai_gen_id }}" class="ai-expert-form__checkbox-label-{{ ai_gen_id }}">Cordones</label>
            </div>
            <div class="ai-expert-form__checkbox-item-{{ ai_gen_id }}">
              <input
                type="checkbox"
                id="product-pens-{{ ai_gen_id }}"
                name="contact[products][]"
                value="Bolígrafos"
                class="ai-expert-form__checkbox-{{ ai_gen_id }}"
              >
              <label for="product-pens-{{ ai_gen_id }}" class="ai-expert-form__checkbox-label-{{ ai_gen_id }}">Bolígrafos</label>
            </div>
            <div class="ai-expert-form__checkbox-item-{{ ai_gen_id }}">
              <input
                type="checkbox"
                id="product-socks-{{ ai_gen_id }}"
                name="contact[products][]"
                value="Medias"
                class="ai-expert-form__checkbox-{{ ai_gen_id }}"
              >
              <label for="product-socks-{{ ai_gen_id }}" class="ai-expert-form__checkbox-label-{{ ai_gen_id }}">Medias</label>
            </div>
            <div class="ai-expert-form__checkbox-item-{{ ai_gen_id }}">
              <input
                type="checkbox"
                id="product-other-{{ ai_gen_id }}"
                name="contact[products][]"
                value="Otros"
                class="ai-expert-form__checkbox-{{ ai_gen_id }}"
              >
              <label for="product-other-{{ ai_gen_id }}" class="ai-expert-form__checkbox-label-{{ ai_gen_id }}">Otros</label>
            </div>
          </div>
        </div>

        <div class="ai-expert-form__field-{{ ai_gen_id }}">
          <label class="ai-expert-form__label-{{ ai_gen_id }}" for="message-{{ ai_gen_id }}">
            {{ block.settings.message_label }} <span class="ai-expert-form__required-{{ ai_gen_id }}">*</span>
          </label>
          <textarea
            id="message-{{ ai_gen_id }}"
            name="contact[body]"
            class="ai-expert-form__textarea-{{ ai_gen_id }}"
            placeholder="{{ block.settings.message_placeholder }}"
            required
          ></textarea>
        </div>

        <button type="submit" class="ai-expert-form__button-{{ ai_gen_id }}">
          {{ block.settings.button_text }}
        </button>

        {%- if form.posted_successfully? -%}
          <div class="ai-expert-form__success-{{ ai_gen_id }}">
            {{ block.settings.success_message }}
          </div>
        {%- endif -%}

        {%- if form.errors -%}
          <div id="ai-expert-form-error-{{ ai_gen_id }}" class="ai-expert-form__error-{{ ai_gen_id }}">
            <p>{{ block.settings.error_message }}</p>
            {% for field in form.errors %}
              <p>{{ field | capitalize }}: {{ form.errors.messages[field] }}</p>
            {% endfor %}
          </div>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>
</div>

