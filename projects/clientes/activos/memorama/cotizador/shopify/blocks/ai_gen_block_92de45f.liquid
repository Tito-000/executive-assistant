{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-brands-section-{{ ai_gen_id }} {
    display: block;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top }}px 20px {{ block.settings.padding_bottom }}px;
  }

  .ai-brands-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
  }

  .ai-brands-content-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    align-items: center;
  }

  .ai-brands-text-column-{{ ai_gen_id }} {
    text-align: center;
  }

  .ai-brands-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 16px;
    font-weight: 600;
    line-height: 1.2;
  }

  .ai-brands-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0;
    line-height: 1.6;
  }

  .ai-brands-logos-column-{{ ai_gen_id }} {
    overflow: hidden;
    width: 100%;
  }

  .ai-brands-carousel-wrapper-{{ ai_gen_id }} {
    display: flex;
    width: fit-content;
  }

  .ai-brands-logos-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.logo_spacing }}px;
  }

  .ai-brands-logos-{{ ai_gen_id }}.ai-carousel-active-{{ ai_gen_id }} {
    animation: ai-brands-scroll-{{ ai_gen_id }} {{ block.settings.carousel_speed }}s linear infinite;
  }

  .ai-brands-logo-item-{{ ai_gen_id }} {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-brands-logo-item-{{ ai_gen_id }} img {
    max-width: {{ block.settings.logo_max_width }}px;
    max-height: {{ block.settings.logo_max_height }}px;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: grayscale({{ block.settings.logo_grayscale }}%);
    opacity: {{ block.settings.logo_opacity | divided_by: 100.0 }};
    transition: all 0.3s ease;
  }

  .ai-brands-logo-item-{{ ai_gen_id }} img:hover {
    filter: grayscale(0%);
    opacity: 1;
  }

  .ai-brands-logo-placeholder-{{ ai_gen_id }} {
    width: {{ block.settings.logo_max_width }}px;
    height: {{ block.settings.logo_max_height }}px;
    background-color: #f0f0f0;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
  }

  .ai-brands-logo-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  @keyframes ai-brands-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media screen and (min-width: 750px) {
    .ai-brands-content-{{ ai_gen_id }} {
      grid-template-columns: {{ block.settings.text_column_width }}% 1fr;
      gap: 60px;
    }

    .ai-brands-text-column-{{ ai_gen_id }} {
      text-align: left;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-brands-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-brands-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }

    .ai-brands-logos-{{ ai_gen_id }} {
      gap: {{ block.settings.logo_spacing | times: 0.7 }}px;
    }

    .ai-brands-logo-item-{{ ai_gen_id }} img {
      max-width: {{ block.settings.logo_max_width | times: 0.75 }}px;
      max-height: {{ block.settings.logo_max_height | times: 0.75 }}px;
    }

    .ai-brands-logo-placeholder-{{ ai_gen_id }} {
      width: {{ block.settings.logo_max_width | times: 0.75 }}px;
      height: {{ block.settings.logo_max_height | times: 0.75 }}px;
    }
  }
{% endstyle %}

<brands-section-{{ ai_gen_id }} class="ai-brands-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-brands-container-{{ ai_gen_id }}">
    <div class="ai-brands-content-{{ ai_gen_id }}">
      <div class="ai-brands-text-column-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-brands-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}

        {% if block.settings.description != blank %}
          <div class="ai-brands-description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
        {% endif %}
      </div>

      <div class="ai-brands-logos-column-{{ ai_gen_id }}">
        <div class="ai-brands-carousel-wrapper-{{ ai_gen_id }}">
          <div class="ai-brands-logos-{{ ai_gen_id }} {% if block.settings.enable_carousel %}ai-carousel-active-{{ ai_gen_id }}{% endif %}">
            {% liquid
              assign has_logos = false
              for i in (1..8)
                assign logo_key = 'logo_' | append: i
                if block.settings[logo_key] != blank
                  assign has_logos = true
                  break
                endif
              endfor
            %}

            {% if has_logos %}
              {% for i in (1..8) %}
                {% liquid
                  assign logo_key = 'logo_' | append: i
                  assign logo = block.settings[logo_key]
                %}
                {% if logo != blank %}
                  <div class="ai-brands-logo-item-{{ ai_gen_id }}">
                    <img
                      src="{{ logo | image_url: width: 400 }}"
                      alt="{{ logo.alt | escape }}"
                      loading="lazy"
                      width="{{ logo.width }}"
                      height="{{ logo.height }}"
                    >
                  </div>
                {% endif %}
              {% endfor %}
            {% else %}
              {% for i in (1..5) %}
                <div class="ai-brands-logo-item-{{ ai_gen_id }}">
                  <div class="ai-brands-logo-placeholder-{{ ai_gen_id }}">
                    {{ 'image' | placeholder_svg_tag }}
                  </div>
                </div>
              {% endfor %}
            {% endif %}
          </div>

          {% if block.settings.enable_carousel %}
            <div class="ai-brands-logos-{{ ai_gen_id }} ai-carousel-active-{{ ai_gen_id }}" aria-hidden="true">
              {% if has_logos %}
                {% for i in (1..8) %}
                  {% liquid
                    assign logo_key = 'logo_' | append: i
                    assign logo = block.settings[logo_key]
                  %}
                  {% if logo != blank %}
                    <div class="ai-brands-logo-item-{{ ai_gen_id }}">
                      <img
                        src="{{ logo | image_url: width: 400 }}"
                        alt="{{ logo.alt | escape }}"
                        loading="lazy"
                        width="{{ logo.width }}"
                        height="{{ logo.height }}"
                      >
                    </div>
                  {% endif %}
                {% endfor %}
              {% else %}
                {% for i in (1..5) %}
                  <div class="ai-brands-logo-item-{{ ai_gen_id }}">
                    <div class="ai-brands-logo-placeholder-{{ ai_gen_id }}">
                      {{ 'image' | placeholder_svg_tag }}
                    </div>
                  </div>
                {% endfor %}
              {% endif %}
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</brands-section-{{ ai_gen_id }}>

<script>
  (function() {
    class BrandsSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.initCarousel();
      }

      initCarousel() {
        const carouselEnabled = {{ block.settings.enable_carousel | json }};
        if (!carouselEnabled) return;

        const logosColumn = this.querySelector('.ai-brands-logos-column-{{ ai_gen_id }}');
        const carouselWrapper = this.querySelector('.ai-brands-carousel-wrapper-{{ ai_gen_id }}');
        
        if (!logosColumn || !carouselWrapper) return;

        logosColumn.addEventListener('mouseenter', () => {
          const activeCarousels = carouselWrapper.querySelectorAll('.ai-carousel-active-{{ ai_gen_id }}');
          activeCarousels.forEach(carousel => {
            carousel.style.animationPlayState = 'paused';
          });
        });

        logosColumn.addEventListener('mouseleave', () => {
          const activeCarousels = carouselWrapper.querySelectorAll('.ai-carousel-active-{{ ai_gen_id }}');
          activeCarousels.forEach(carousel => {
            carousel.style.animationPlayState = 'running';
          });
        });
      }
    }

    customElements.define('brands-section-{{ ai_gen_id }}', BrandsSection{{ ai_gen_id }});
  })();
</script>

