<script>
  (function() {
    class TrustBar{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.carousel = this.querySelector('.ai-trust-bar-carousel-{{ ai_gen_id }}');
        this.items = this.querySelectorAll('.ai-trust-bar-item-{{ ai_gen_id }}');
        this.currentIndex = 0;
        this.autoplayInterval = null;
        this.isPaused = false;
        this.isMobile = window.innerWidth < 750;
      }

      connectedCallback() {
        this.checkMobile();
        window.addEventListener('resize', () => this.handleResize());
        
        if (this.isMobile && this.items.length > 1) {
          this.startAutoplay();
          this.setupTouchEvents();
        }
      }

      checkMobile() {
        this.isMobile = window.innerWidth < 750;
      }

      handleResize() {
        const wasMobile = this.isMobile;
        this.checkMobile();
        
        if (wasMobile !== this.isMobile) {
          if (this.isMobile && this.items.length > 1) {
            this.startAutoplay();
            this.setupTouchEvents();
          } else {
            this.stopAutoplay();
            if (this.carousel) {
              this.carousel.style.transform = 'translateX(0)';
            }
          }
        }
      }

      startAutoplay() {
        if (!this.isMobile || this.items.length <= 1) return;
        
        const speed = parseInt(this.dataset.speed) || 4;
        this.autoplayInterval = setInterval(() => {
          if (!this.isPaused) {
            this.nextSlide();
          }
        }, speed * 1000);
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      nextSlide() {
        if (!this.isMobile || this.items.length <= 1) return;
        
        this.currentIndex = (this.currentIndex + 1) % this.items.length;
        this.updateCarousel();
      }

      updateCarousel() {
        if (!this.carousel || !this.isMobile) return;
        
        const offset = -this.currentIndex * 100;
        this.carousel.style.transform = `translateX(${offset}%)`;
      }

      setupTouchEvents() {
        if (!this.isMobile) return;
        
        this.addEventListener('touchstart', () => {
          this.isPaused = true;
        });

        this.addEventListener('touchend', () => {
          setTimeout(() => {
            this.isPaused = false;
          }, 2000);
        });

        this.addEventListener('mouseenter', () => {
          this.isPaused = true;
        });

        this.addEventListener('mouseleave', () => {
          this.isPaused = false;
        });
      }

      disconnectedCallback() {
        this.stopAutoplay();
        window.removeEventListener('resize', () => this.handleResize());
      }
    }

    customElements.define('trust-bar-{{ ai_gen_id }}', TrustBar{{ ai_gen_id }});
  })();
</script>

