{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-steps-block-{{ ai_gen_id }} {
    display: block;
    background-color: {{ block.settings.background_color }};
    padding: 80px 20px;
    width: 100%;
  }

  .ai-steps-block-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-steps-block-wrapper-{{ ai_gen_id }} {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    gap: 60px;
    margin-bottom: 60px;
  }

  .ai-steps-block-line-{{ ai_gen_id }} {
    position: absolute;
    top: 45px;
    left: 50%;
    transform: translateX(-50%);
    width: 60%;
    height: 1px;
    background-color: {{ block.settings.line_color }};
    z-index: 0;
  }

  .ai-steps-block-step-{{ ai_gen_id }} {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    flex: 1;
    max-width: 280px;
    z-index: 1;
  }

  .ai-steps-block-circle-{{ ai_gen_id }} {
    width: 90px;
    height: 90px;
    border-radius: 50%;
    background-color: {{ block.settings.circle_background }};
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .ai-steps-block-number-{{ ai_gen_id }} {
    font-size: 32px;
    font-weight: 700;
    color: {{ block.settings.number_color }};
    line-height: 1;
  }

  .ai-steps-block-text-{{ ai_gen_id }} {
    text-align: center;
    color: {{ block.settings.text_color }};
    font-size: 16px;
    font-weight: 600;
    line-height: 1.4;
    max-width: 200px;
  }

  .ai-steps-block-button-{{ ai_gen_id }} {
    display: block;
    width: 60%;
    max-width: 700px;
    margin: 0 auto;
    padding: 22px 45px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-align: center;
    text-decoration: none;
    border-radius: 50px;
    font-size: 16px;
    font-weight: 500;
    line-height: 1.4;
    transition: background-color 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .ai-steps-block-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  @media screen and (max-width: 749px) {
    .ai-steps-block-{{ ai_gen_id }} {
      padding: 40px 15px;
    }

    .ai-steps-block-wrapper-{{ ai_gen_id }} {
      gap: 10px;
      margin-bottom: 40px;
      padding: 0 5px;
    }

    .ai-steps-block-line-{{ ai_gen_id }} {
      display: none;
    }

    .ai-steps-block-step-{{ ai_gen_id }} {
      flex: 1;
      min-width: 0;
      max-width: none;
      gap: 12px;
    }

    .ai-steps-block-circle-{{ ai_gen_id }} {
      width: 55px;
      height: 55px;
    }

    .ai-steps-block-number-{{ ai_gen_id }} {
      font-size: 20px;
    }

    .ai-steps-block-text-{{ ai_gen_id }} {
      font-size: 12px;
      max-width: 100%;
      padding: 0 2px;
    }

    .ai-steps-block-button-{{ ai_gen_id }} {
      width: 95%;
      padding: 16px 20px;
      font-size: 14px;
    }
  }
{% endstyle %}

<steps-block-{{ ai_gen_id }} class="ai-steps-block-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-steps-block-container-{{ ai_gen_id }}">
    <div class="ai-steps-block-wrapper-{{ ai_gen_id }}">
      <div class="ai-steps-block-line-{{ ai_gen_id }}"></div>
      
      <div class="ai-steps-block-step-{{ ai_gen_id }}">
        <div class="ai-steps-block-circle-{{ ai_gen_id }}">
          <span class="ai-steps-block-number-{{ ai_gen_id }}">{{ block.settings.step_1_number }}</span>
        </div>
        <p class="ai-steps-block-text-{{ ai_gen_id }}">{{ block.settings.step_1_text }}</p>
      </div>

      <div class="ai-steps-block-step-{{ ai_gen_id }}">
        <div class="ai-steps-block-circle-{{ ai_gen_id }}">
          <span class="ai-steps-block-number-{{ ai_gen_id }}">{{ block.settings.step_2_number }}</span>
        </div>
        <p class="ai-steps-block-text-{{ ai_gen_id }}">{{ block.settings.step_2_text }}</p>
      </div>

      <div class="ai-steps-block-step-{{ ai_gen_id }}">
        <div class="ai-steps-block-circle-{{ ai_gen_id }}">
          <span class="ai-steps-block-number-{{ ai_gen_id }}">{{ block.settings.step_3_number }}</span>
        </div>
        <p class="ai-steps-block-text-{{ ai_gen_id }}">{{ block.settings.step_3_text }}</p>
      </div>
    </div>

    {% if block.settings.button_text != blank %}
      <a href="{{ block.settings.button_link }}" class="ai-steps-block-button-{{ ai_gen_id }}">
        {{ block.settings.button_text }}
      </a>
    {% endif %}
  </div>
</steps-block-{{ ai_gen_id }}>

<script>
  (function() {
    class StepsBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }

    customElements.define('steps-block-{{ ai_gen_id }}', StepsBlock{{ ai_gen_id }});
  })();
</script>

