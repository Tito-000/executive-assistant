            <div class="ai-grid-image-wrapper-{{ ai_gen_id }}">
              {% if block.settings.column_2_image %}
                <img
                  src="{{ block.settings.column_2_image | image_url: width: 600 }}"
                  alt="{{ block.settings.column_2_image.alt | escape }}"
                  loading="lazy"
                  width="{{ block.settings.column_2_image.width }}"
                  height="{{ block.settings.column_2_image.height }}"
                  class="ai-grid-image-{{ ai_gen_id }}"
                >
              {% else %}
                {{ 'product-2' | placeholder_svg_tag }}
              {% endif %}
            </div>

            {% if block.settings.column_2_description != blank %}
              <p class="ai-grid-description-{{ ai_gen_id }}">
                {{ block.settings.column_2_description }}
              </p>
            {% endif %}

          {% if block.settings.column_2_link != blank %}
            </a>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.column_3_enabled %}
        <div class="ai-grid-column-{{ ai_gen_id }}">
          {% if block.settings.column_3_link != blank %}
            <a href="{{ block.settings.column_3_link }}" class="ai-grid-link-{{ ai_gen_id }}">
          {% endif %}
            
            {% if block.settings.column_3_title != blank %}
              <h3 class="ai-grid-column-title-{{ ai_gen_id }}">
                {{ block.settings.column_3_title }}
              </h3>
            {% endif %}

            <div class="ai-grid-image-wrapper-{{ ai_gen_id }}">
              {% if block.settings.column_3_image %}
                <img
                  src="{{ block.settings.column_3_image | image_url: width: 600 }}"
                  alt="{{ block.settings.column_3_image.alt | escape }}"
                  loading="lazy"
                  width="{{ block.settings.column_3_image.width }}"
                  height="{{ block.settings.column_3_image.height }}"
                  class="ai-grid-image-{{ ai_gen_id }}"
                >
              {% else %}
                {{ 'product-3' | placeholder_svg_tag }}
              {% endif %}
            </div>

            {% if block.settings.column_3_description != blank %}
              <p class="ai-grid-description-{{ ai_gen_id }}">
                {{ block.settings.column_3_description }}
              </p>
            {% endif %}

          {% if block.settings.column_3_link != blank %}
            </a>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.column_4_enabled %}
        <div class="ai-grid-column-{{ ai_gen_id }}">
          {% if block.settings.column_4_link != blank %}
            <a href="{{ block.settings.column_4_link }}" class="ai-grid-link-{{ ai_gen_id }}">
          {% endif %}
            
            {% if block.settings.column_4_title != blank %}
              <h3 class="ai-grid-column-title-{{ ai_gen_id }}">
                {{ block.settings.column_4_title }}
              </h3>
            {% endif %}

            <div class="ai-grid-image-wrapper-{{ ai_gen_id }}">
              {% if block.settings.column_4_image %}
                <img
                  src="{{ block.settings.column_4_image | image_url: width: 600 }}"
                  alt="{{ block.settings.column_4_image.alt | escape }}"
                  loading="lazy"
                  width="{{ block.settings.column_4_image.width }}"
                  height="{{ block.settings.column_4_image.height }}"
                  class="ai-grid-image-{{ ai_gen_id }}"
                >
              {% else %}
                {{ 'product-4' | placeholder_svg_tag }}
              {% endif %}
            </div>

            {% if block.settings.column_4_description != blank %}
              <p class="ai-grid-description-{{ ai_gen_id }}">
                {{ block.settings.column_4_description }}
              </p>
            {% endif %}

          {% if block.settings.column_4_link != blank %}
            </a>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</div>

