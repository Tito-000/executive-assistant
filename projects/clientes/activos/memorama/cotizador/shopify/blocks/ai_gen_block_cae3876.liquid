{% doc %}
  @prompt
    Crea una sección de contenido en formato de cuadrícula (grid) para una tienda Shopify, con 4 columnas en desktop y diseño limpio, corporativo y moderno, totalmente editable desde el editor de temas.
    
    Estructura de la sección:
    
    Título de categoría en la parte superior de cada columna.
    
    Imagen principal debajo del título, con bordes redondeados y fondo neutro.
    
    Texto descriptivo corto debajo de cada imagen.
    
    Columnas (contenido editable):
    
    Columna 1
    
    Título: Eventos y exposiciones
    
    Descripción:
    Productos de marca para ser vistos, reconocidos y recordados.
    
    Columna 2
    
    Título: Uniformes y ropa de trabajo
    
    Descripción:
    Ropa cómoda y confiable para uso diario en equipo.
    
    Columna 3
    
    Título: Promociones y obsequios
    
    Descripción:
    Artículos de marca diseñados para apoyar campañas y lanzamientos.
    
    Columna 4
    
    Título: Mercancía para reventa
    
    Descripción:
    Productos personalizados diseñados para reventa y distribución.
    
    Requisitos de diseño:
    
    Tipografía clara y legible.
    
    Espaciado amplio entre columnas.
    
    Imágenes centradas y del mismo tamaño.
    
    Estilo profesional B2B/e-commerce.
    
    Comportamiento responsive:
    
    Desktop: 4 columnas alineadas horizontalmente.
    
    Tablet: 2 columnas por fila.
    
    Mobile: 1 columna por fila, con buen espaciado vertical.
    
    Requisitos de edición:
    
    Cada columna debe ser editable individualmente:
    
    Título
    
    Imagen
    
    Texto
    
    Enlace opcional
    
    Ajustes globales desde el theme customizer:
    
    Color del texto
    
    Tamaño de fuente
    
    Espaciado entre columnas
    
    Activar o desactivar columnas
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-grid-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-grid-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
  }

  .ai-grid-columns-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.column_gap }}px;
  }

  .ai-grid-column-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .ai-grid-column-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    font-weight: 600;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px;
    line-height: 1.3;
  }

  .ai-grid-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    margin-bottom: {{ block.settings.image_spacing }}px;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
    background-color: {{ block.settings.image_background }};
  }

  .ai-grid-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-grid-image-wrapper-{{ ai_gen_id }} svg {
    width: 100%;
    height: 250px;
    object-fit: cover;
  }

  .ai-grid-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_font_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
    margin: 0;
  }

  .ai-grid-link-{{ ai_gen_id }} {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .ai-grid-link-{{ ai_gen_id }}:hover .ai-grid-image-{{ ai_gen_id }} {
    opacity: 0.9;
    transition: opacity 0.3s ease;
  }

  @media screen and (max-width: 989px) {
    .ai-grid-columns-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      gap: {{ block.settings.column_gap | times: 0.8 }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-grid-section-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.7 }}px 16px {{ block.settings.section_padding_bottom | times: 0.7 }}px;
    }

    .ai-grid-columns-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.mobile_column_gap }}px;
    }

    .ai-grid-column-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size | times: 0.9 }}px;
    }

    .ai-grid-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_font_size | times: 0.95 }}px;
    }
  }
{% endstyle %}

<div class="ai-grid-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-grid-container-{{ ai_gen_id }}">
    <div class="ai-grid-columns-{{ ai_gen_id }}">
      {% if block.settings.column_1_enabled %}
        <div class="ai-grid-column-{{ ai_gen_id }}">
          {% if block.settings.column_1_link != blank %}
            <a href="{{ block.settings.column_1_link }}" class="ai-grid-link-{{ ai_gen_id }}">
          {% endif %}
            
            {% if block.settings.column_1_title != blank %}
              <h3 class="ai-grid-column-title-{{ ai_gen_id }}">
                {{ block.settings.column_1_title }}
              </h3>
            {% endif %}

            <div class="ai-grid-image-wrapper-{{ ai_gen_id }}">
              {% if block.settings.column_1_image %}
                <img
                  src="{{ block.settings.column_1_image | image_url: width: 600 }}"
                  alt="{{ block.settings.column_1_image.alt | escape }}"
                  loading="lazy"
                  width="{{ block.settings.column_1_image.width }}"
                  height="{{ block.settings.column_1_image.height }}"
                  class="ai-grid-image-{{ ai_gen_id }}"
                >
              {% else %}
                {{ 'product-1' | placeholder_svg_tag }}
              {% endif %}
            </div>

            {% if block.settings.column_1_description != blank %}
              <p class="ai-grid-description-{{ ai_gen_id }}">
                {{ block.settings.column_1_description }}
              </p>
            {% endif %}

          {% if block.settings.column_1_link != blank %}
            </a>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.column_2_enabled %}
        <div class="ai-grid-column-{{ ai_gen_id }}">
          {% if block.settings.column_2_link != blank %}
