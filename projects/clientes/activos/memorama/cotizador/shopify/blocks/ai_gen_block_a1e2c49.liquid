{% doc %}
  @prompt
    hAZ UN BOTON 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-button-container-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-button-wrapper-{{ ai_gen_id }} {
    display: flex;
    justify-content: {{ block.settings.alignment }};
    width: 100%;
  }

  .ai-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.text_color }};
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.hover_color }};
    color: {{ block.settings.hover_text_color }};
    border-color: {{ block.settings.hover_border_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-button-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.desktop_width_percent }}%;
    }
  }

  @media screen and (min-width: 750px) {
    .ai-button-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.desktop_width_percent }}%;
    }
  }
{% endstyle %}

<div class="ai-button-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-button-wrapper-{{ ai_gen_id }}">
    <a href="{{ block.settings.button_link }}" class="ai-button-{{ ai_gen_id }}">
      {{ block.settings.button_text }}
    </a>
  </div>
</div>

{% schema %}
{
  "name": "Botón",
  "settings": [
    {
      "type": "header",
      "content": "Contenido"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Texto del botón",
      "default": "Haz clic aquí"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Enlace del botón"
    },
    {
      "type": "header",
      "content": "Diseño"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alineación",
      "options": [
        {
          "value": "flex-start",
          "label": "Izquierda"
        },
        {
          "value": "center",
          "label": "Centro"
        },
        {
          "value": "flex-end",
          "label": "Derecha"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Ancho en escritorio",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Colores"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Color de fondo",
      "default": "#797068"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color del texto",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "hover_color",
      "label": "Color de fondo al pasar el cursor",
      "default": "#413a35"
    },
    {
      "type": "color",
      "id": "hover_text_color",
      "label": "Color del texto al pasar el cursor",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Borde"
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "Grosor del borde",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Color del borde",
      "default": "#797068"
    },
    {
      "type": "color",
      "id": "hover_border_color",
      "label": "Color del borde al pasar el cursor",
      "default": "#413a35"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Radio del borde",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 6
    },
    {
      "type": "header",
      "content": "Tamaño"
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "label": "Relleno vertical",
      "min": 5,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Relleno horizontal",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Tamaño de fuente",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Peso de fuente",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medio"
        },
        {
          "value": "600",
          "label": "Semi-negrita"
        },
        {
          "value": "700",
          "label": "Negrita"
        }
      ],
      "default": "500"
    }
  ],
  "presets": [
    {
      "name": "Botón"
    }
  ],
  "tag": null
}
{% endschema %}
